        {
            "parameters": {
                "jsCode": "const items = $input.all();\nconst errors = [];\nfor (const item of items) {\n  const data = item.json;\n  console.log('PIPELINE ERROR DATA: ', JSON.stringify(data, null, 2));\n  if (data.success === true || (data.sections && data.abstract)) continue;\n  let nodeName = data.node || (data.context && data.context.nodeName) || 'unknown';\n  let msg = 'Unknown error';\n  if (data.response && data.response.body) msg = JSON.stringify(data.response.body);\n  else if (data.message) msg = (typeof data.message === 'object') ? JSON.stringify(data.message) : data.message;\n  else if (data.error) msg = (typeof data.error === 'object') ? JSON.stringify(data.error) : data.error;\n  errors.push({ node: nodeName, message: msg });\n}\nif (errors.length === 0) return items;\nreturn [{ json: { success: false, errors: errors, message: 'Pipeline failed: ' + errors.map(e => e.message).join(' | ') } }];"
            },
