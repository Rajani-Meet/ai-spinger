                "jsCode": "try {\n  let body = ($json && $json.body) || ($json && $json.query) || $json || {};\n  if (typeof body === 'string') {\n    try { body = JSON.parse(body); } catch(e) {}\n  }\n  \n  const authors = Array.isArray(body.authors) && body.authors.length > 0 ? body.authors : [\n    { name: \"Rajani-Meet\", affiliation: \"Research Institution\", email: \"rajani-meet@research.edu\" },\n    { name: \"Jane Smith\", affiliation: \"University of Technology\", email: \"jsmith@university.edu\" }\n  ];\n  \n  return [{\n    json: {\n      github_url: body.github_url || ($json && $json.github_url) || 'https://github.com/Rajani-Meet/CodeForge-Hub',\n      branch: body.branch || ($json && $json.branch) || 'main',\n      authors: authors,\n      style_reference: body.style_reference || '',\n      project_overview: body.project_overview || '',\n      target_pages: body.target_pages ? parseInt(body.target_pages) : 10\n    }\n  }];\n} catch (e) {\n  return [{ json: { error: e.message, github_url: 'https://github.com/Rajani-Meet/CodeForge-Hub', branch: 'main' } }];\n}"
            },
